{
  "expo": {
    "name": "Gorakh Chat",
    "slug": "gorakh-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "android": {
      "package": "com.airudra00.gorakhchat",
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_ADVERTISE",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "NEARBY_WIFI_DEVICES"
      ]
    },
    "splash": {
      "backgroundColor": "#0F172A"
    },
    "plugins": [
      "@morrowdigital/watermelondb-expo-plugin"
    ]
  }
}
