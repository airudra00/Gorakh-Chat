{
  "expo": {
    "name": "Gorakh Chat",
    "slug": "gorakh-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "android": {
      "package": "com.airudra00.gorakhchat",
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_ADVERTISE",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "NEARBY_WIFI_DEVICES",
        "ACCESS_WIFI_STATE",
        "CHANGE_WIFI_STATE",
        "INTERNET"
      ]
    },
    "splash": {
      "backgroundColor": "#0F172A"
    },
    "plugins": [
      "@morrowdigital/watermelondb-expo-plugin",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": ["peripheral", "central"],
          "bluetoothAlwaysPermission": "Allow Gorakh Chat to find nearby users offline."
        }
      ]
    ]
  }
}
